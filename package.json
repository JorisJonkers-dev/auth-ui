{
  "name": "@jorisjonkers-dev/auth-ui",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "typecheck": "vue-tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "depcruise": "depcruise src --config .dependency-cruiser.cjs --output-type err",
    "stryker": "stryker run",
    "verify": "pnpm lint && pnpm typecheck && pnpm test:coverage && pnpm depcruise && pnpm build"
  },
  "dependencies": {
    "@grafana/faro-web-sdk": "^2.7.1",
    "@grafana/faro-web-tracing": "^2.7.1",
    "@jorisjonkers-dev/auth-api-client": "0.1.0",
    "@jorisjonkers-dev/vue-web-commons": "0.4.0",
    "pinia": "^3.0.4",
    "primevue": "^4.5.5",
    "qrcode": "^1.5.4",
    "vue": "^3.5.35",
    "vue-router": "^5.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.0.0",
    "@playwright/test": "^1.60.0",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@tailwindcss/vite": "^4.3.0",
    "@types/qrcode": "^1.5.6",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-v8": "^4.1.7",
    "@vue/test-utils": "^2.4.10",
    "dependency-cruiser": "^17.4.2",
    "eslint": "^10.4.1",
    "jiti": "^2.7.0",
    "jsdom": "^29.1.1",
    "msw": "^2.14.6",
    "prettier": "^3.7.4",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "vitest": "^4.1.7",
    "vue-tsc": "^3.3.2"
  }
}
