{
  "name": "@personal-stack/auth-ui",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "typecheck": "vue-tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "depcruise": "depcruise src --config .dependency-cruiser.cjs --output-type err",
    "stryker": "stryker run"
  },
  "dependencies": {
    "@personal-stack/vue-common": "workspace:*",
    "pinia": "^2.3.1",
    "primevue": "^4.3.3",
    "qrcode": "^1.5.4",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.51.1",
    "@stryker-mutator/core": "^8.7.1",
    "@stryker-mutator/vitest-runner": "^8.7.1",
    "@tailwindcss/vite": "^4.1.1",
    "@types/qrcode": "^1.5.6",
    "@vitejs/plugin-vue": "^5.2.3",
    "@vue/test-utils": "^2.4.6",
    "dependency-cruiser": "^16.9.0",
    "jsdom": "^26.0.0",
    "msw": "^2.7.3",
    "tailwindcss": "^4.1.1",
    "typescript": "^5.7.3",
    "vite": "^6.2.4",
    "vitest": "^3.1.1",
    "vue-tsc": "^2.2.8"
  }
}
